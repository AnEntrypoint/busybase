{
  "name": "busybase",
  "version": "1.0.0",
  "type": "module",
  "description": "HTTP SQLite database that feels like Supabase — drop-in headless backend powered by Bun",
  "main": "./src/sdk.ts",
  "module": "./src/sdk.ts",
  "exports": {
    ".": "./src/sdk.ts",
    "./embedded": "./src/embedded.ts",
    "./server": "./src/server.ts"
  },
  "bin": {
    "busybase": "./src/cli.ts"
  },
  "scripts": {
    "start": "bun run src/cli.ts serve",
    "test": "bun run src/cli.ts test"
  },
  "files": [
    "src/server.ts",
    "src/sdk.ts",
    "src/cli.ts",
    "src/embedded.ts",
    "src/hooks.ts",
    "src/realtime.ts"
  ],
  "dependencies": {
    "vectordb": "^0.21.2"
  },
  "keywords": ["database", "sqlite", "supabase", "rest", "api", "bun", "backend", "vector"],
  "author": "AnEntrypoint",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/AnEntrypoint/busybase.git"
  }
}
